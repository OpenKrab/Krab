{
  "name": "krab-desktop",
  "version": "1.0.0",
  "description": "🦀 Krab - AGI Agent Framework Desktop Application",
  "main": "dist/main.js",
  "homepage": "https://github.com/pollinations/krab",
  "author": "Krab Team",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:main": "tsc -p tsconfig.main.json && electron dist/main.js --dev",
    "dev:renderer": "vite",
    "build": "npm run build:renderer && npm run build:main",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "build:all": "npm run build && electron-builder",
    "dist": "npm run build:all",
    "pack": "npm run build && electron-builder --dir",
    "start": "electron dist/main.js",
    "test": "jest",
    "lint": "eslint . --ext .ts,.js,.tsx,.jsx",
    "lint:fix": "eslint . --ext .ts,.js,.tsx,.jsx --fix",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "electron": "^28.0.0",
    "electron-updater": "^6.1.7"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/jest": "^29.5.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "concurrently": "^8.2.0",
    "electron-builder": "^24.6.0",
    "eslint": "^8.0.0",
    "jest": "^29.7.0"
  },
  "build": {
    "appId": "com.krab.desktop",
    "productName": "Krab",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        }
      ]
    }
  },
  "keywords": [
    "ai",
    "agent",
    "framework",
    "automation",
    "voice",
    "chatbot",
    "desktop",
    "electron"
  ]
}
