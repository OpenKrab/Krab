# Railway Configuration for Krab
{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm run build"
  },
  "deploy": {
    "startCommand": "npm run start:prod",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  },
  "environments": {
    "production": {
      "envVars": [
        {
          "name": "NODE_ENV",
          "value": "production"
        },
        {
          "name": "KRAB_RAILWAY",
          "value": "true"
        },
        {
          "name": "PORT",
          "value": "$PORT"
        }
      ]
    }
  }
}
