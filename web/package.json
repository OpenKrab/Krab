{
  "name": "krab-web",
  "version": "1.0.0",
  "description": "🦀 Krab - Web Interface Server",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsc watch server.ts --outDir dist",
    "dev:client": "vite",
    "build": "npm run build:server && npm run build:client",
    "build:server": "tsc server.ts --outDir dist",
    "build:client": "vite build",
    "start": "node dist/server.js",
    "test": "jest",
    "lint": "eslint . --ext .ts,.js",
    "lint:fix": "eslint . --ext .ts,.js --fix"
  },
  "dependencies": {
    "express": "^4.18.0",
    "socket.io": "^4.7.0",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/express": "^4.17.0",
    "@types/cors": "^2.8.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "concurrently": "^8.2.0",
    "eslint": "^8.0.0",
    "jest": "^29.7.0"
  },
  "keywords": [
    "krab",
    "web-interface",
    "socket.io",
    "real-time",
    "chat",
    "ai",
    "voice"
  ]
}
